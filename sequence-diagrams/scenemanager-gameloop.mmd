sequenceDiagram
    title RPG Maker MZ — Game Loop

    actor User as Usuario
    participant PIXIApp as PIXI.Application
    participant Graphics
    participant SceneManager
    participant AudioManager
    participant Input
    participant TouchInput
    participant Window as window

    loop app.ticker.started
        PIXIApp->>Graphics: _onTick(deltaTime)
        activate Graphics
        Graphics->>Graphics: _fpsCounter.startTick()
        Graphics->>SceneManager: update(deltaTime)
        activate SceneManager
        SceneManager->>SceneManager: determineRepeatNumber(deltaTime)
        loop i < n
            SceneManager->>SceneManager: updateMain()
            activate SceneManager
            SceneManager->>SceneManager: updateFrameCount()
            SceneManager->>SceneManager: updateInputData()
            activate SceneManager
            SceneManager->>Input: update()
            SceneManager->>TouchInput: update()
            deactivate SceneManager
            SceneManager->>SceneManager: updateEffekseer()
            SceneManager->>SceneManager: changeScene()
            SceneManager->>SceneManager: updateScene()
            deactivate SceneManager
        end
        break excepción en updateMain() — capturada en update()
            SceneManager->>SceneManager: catchException(e)
            activate SceneManager
            alt e instanceof Error
                SceneManager->>SceneManager: catchNormalError(e)
                activate SceneManager
                SceneManager->>Graphics: printError(e.name, e.message, e)
                SceneManager->>AudioManager: stopAll()
                SceneManager->>SceneManager: console.error(e.stack)
                deactivate SceneManager
            else e instanceof Array && e[0] === "LoadError"
                note over SceneManager: LoadError de: ImageManager / FontManager / AudioManager / EffectManager
                SceneManager->>SceneManager: catchLoadError(e)
                activate SceneManager
                SceneManager->>Graphics: printError("Failed to load", url)
                alt retry
                    SceneManager->>Graphics: showRetryButton(callback)
                else !retry
                    SceneManager->>AudioManager: stopAll()
                end
                deactivate SceneManager
            else
                SceneManager->>SceneManager: catchUnknownError(e)
                activate SceneManager
                SceneManager->>Graphics: printError("UnknownError", String(e))
                SceneManager->>AudioManager: stopAll()
                deactivate SceneManager
            end
            SceneManager->>SceneManager: stop()
            activate SceneManager
            SceneManager->>Graphics: stopGameLoop()
            activate Graphics
            Graphics->>PIXIApp: stop()
            deactivate Graphics
            deactivate SceneManager
            opt retry
                User-)Graphics: click
                activate Graphics
                Graphics->>Graphics: eraseError()
                note right of Graphics: onclick → closure de catchLoadError: retry() [e[2]]
                Graphics->>SceneManager: resume()
                activate SceneManager
                SceneManager->>TouchInput: update()
                SceneManager->>Graphics: startGameLoop()
                activate Graphics
                Graphics->>PIXIApp: start()
                deactivate Graphics
                deactivate SceneManager
                deactivate Graphics
            end
            deactivate SceneManager
        end
        deactivate SceneManager
        opt _canRender()
            Graphics->>PIXIApp: render()
            activate PIXIApp
            deactivate PIXIApp
        end
        Graphics->>Graphics: _fpsCounter.endTick()
        deactivate Graphics
    end

    par eventos asíncronos
        Window-)SceneManager: error
        activate SceneManager
        SceneManager->>SceneManager: onError(event)
        activate SceneManager
        SceneManager->>SceneManager: console.error(event.message)
        SceneManager->>SceneManager: console.error(event.filename, event.lineno)
        SceneManager->>SceneManager: stop()
        activate SceneManager
        SceneManager->>Graphics: stopGameLoop()
        activate Graphics
        Graphics->>PIXIApp: stop()
        deactivate Graphics
        deactivate SceneManager
        SceneManager->>Graphics: printError("Error", event.message, event)
        SceneManager->>AudioManager: stopAll()
        deactivate SceneManager
        deactivate SceneManager
    and
        Window-)SceneManager: unhandledrejection
        activate SceneManager
        SceneManager->>SceneManager: onReject(event)
        activate SceneManager
        SceneManager->>SceneManager: onError(event)
        activate SceneManager
        SceneManager->>SceneManager: console.error(event.message)
        SceneManager->>SceneManager: console.error(event.filename, event.lineno)
        SceneManager->>SceneManager: stop()
        activate SceneManager
        SceneManager->>Graphics: stopGameLoop()
        activate Graphics
        Graphics->>PIXIApp: stop()
        deactivate Graphics
        deactivate SceneManager
        SceneManager->>Graphics: printError("Error", event.message, event)
        SceneManager->>AudioManager: stopAll()
        deactivate SceneManager
        deactivate SceneManager
        deactivate SceneManager
    end
